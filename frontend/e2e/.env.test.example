# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit it.

# --- App base URLs ---
BASE_URL=http://localhost:5173          # local Vite dev server
DOCKER_URL=http://localhost:3000        # local docker-compose (nginx port)
HOMELAB_URL=https://wled.lab.ri.tronkowski.net  # deployed homelab instance

# --- Dedicated test controllers ---
# These devices will be targeted by E2E tests.
# Use controllers that are safe to have their state changed during testing.

TEST_CONTROLLER_1_NAME=Mega Tree 1
TEST_CONTROLLER_1_IP=192.168.5.59

TEST_CONTROLLER_2_NAME=Mega Tree 2
TEST_CONTROLLER_2_IP=192.168.5.46

TEST_CONTROLLER_3_NAME=Mega Tree 3
TEST_CONTROLLER_3_IP=192.168.5.49
